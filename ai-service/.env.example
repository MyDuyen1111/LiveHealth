# LiveHealth AI Service configuration template

# OpenAI-compatible GPT provider
# OPENAI_API_BASE may include or omit /v1; both are supported.
# Examples:
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com
# OPENAI_API_BASE=http://localhost:8317/v1
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# MySQL (same database used by backend)
MYSQL_HOST=localhost
MYSQL_PORT=62307
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=livehealth
